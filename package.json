{
  "name": "bellwire",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:live": "node scripts/live-smoke.mjs",
    "build": "wrangler deploy --dry-run --outdir dist",
    "web:dev": "npm --prefix website run dev",
    "web:build": "npm --prefix website run build",
    "web:preview": "npm --prefix website run preview",
    "ios:build": "xcodebuild -project ios/Bellwire/Bellwire.xcodeproj -scheme Bellwire -sdk iphonesimulator -configuration Debug CODE_SIGNING_ALLOWED=NO build"
  },
  "dependencies": {
    "hono": "^4.8.5",
    "jose": "^6.2.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260714.1",
    "@eslint/js": "^9.31.0",
    "eslint": "^9.31.0",
    "globals": "^17.7.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.38.0",
    "vitest": "^3.2.4",
    "wrangler": "^4.25.0"
  },
  "engines": {
    "node": ">=20"
  }
}
