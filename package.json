{
  "name": "bellwire",
  "version": "0.1.0",
  "private": true,
  "license": "SEE LICENSE IN LICENSE.md",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:worker": "vitest run --exclude test/ios-preview.test.js",
    "test:ios": "vitest run test/ios-preview.test.js",
    "test:watch": "vitest",
    "test:live": "node scripts/live-smoke.mjs",
    "self-host:bootstrap": "node scripts/self-host-bootstrap.mjs",
    "self-host:doctor": "node scripts/self-host-doctor.mjs",
    "self-host:apns-preflight": "node scripts/apns-preflight.mjs",
    "build": "wrangler deploy --dry-run --outdir dist",
    "ios:build": "xcodebuild -project ios/Bellwire/Bellwire.xcodeproj -scheme Bellwire -sdk iphonesimulator -configuration Debug CODE_SIGNING_ALLOWED=NO build"
  },
  "dependencies": {
    "@apple/app-store-server-library": "^3.1.0",
    "hono": "^4.8.5",
    "jose": "^6.2.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260714.1",
    "@eslint/js": "^9.31.0",
    "eslint": "^9.31.0",
    "globals": "^17.7.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.38.0",
    "vitest": "^4.1.10",
    "wrangler": "^4.25.0"
  },
  "engines": {
    "node": ">=22"
  }
}
